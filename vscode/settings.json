{
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "catppuccin-mocha",
  "explorer.compactFolders": false, // ファイルがないフォルダをコンパクト表示しない
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "editor.fontFamily": "'Moralerspace Xenon'",
  "editor.fontSize": 16,
  "editor.minimap.enabled": false,
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "editor.renderWhitespace": "boundary",
  "terminal.integrated.fontFamily": "'Moralerspace Xenon NF'",
  "terminal.integrated.fontSize": 16,
  "[markdown]": {
    "files.trimTrailingWhitespace": false,
    "editor.wordWrap": "on",
    "editor.tabSize": 4, // Markdownはスペース4つでないと正常にパースできない場合がある
    "diffEditor.ignoreTrimWhitespace": false
  },
  // ========================================================================
  // Extension: VSCode Neovim
  // ========================================================================
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  // ========================================================================
  // Extension: Markdown all in one
  // ========================================================================
  "markdown.extension.list.indentationSize": "inherit",
  // ========================================================================
  // Extension: Markdown preview enhanced
  // ========================================================================
  "markdown-preview-enhanced.mermaidTheme": "dark",
  "markdown-preview-enhanced.codeBlockTheme": "github-dark.css",
  "markdown-preview-enhanced.previewTheme": "github-dark.css",
  // ========================================================================
  // Extension: Markdownlint
  // ========================================================================
  "markdownlint.config": {
    "default": true,
    "MD007": { "indent": 4 }
  }
}
