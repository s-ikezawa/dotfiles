#!/bin/bash

{{ if eq .chezmoi.os "darwin" -}}
mkdir -p $HOME/.config/zsh $HOME/.cache/zsh $HOME/.local/share $HOME/.local/state

/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

echo "ZDOTDIR=$HOME/.config/zsh" | sudo tee -a /etc/zshenv > /dev/null
{{- end }}
