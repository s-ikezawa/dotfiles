# Git設定ファイル
# ~/.config/git/config
# 注意: ユーザー情報は個別に設定してください
# git config --global user.name "Your Name"
# git config --global user.email "your.email@example.com"

[core]
	editor = code --wait
	autocrlf = input

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	default = simple

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	lg = log --oneline --graph --decorate --all
