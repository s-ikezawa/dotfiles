{
  "inputs": [
    {
      "type": "promptString",
      "id": "pogtgres_url",
      "description": "PostgreSQL URL (e.g. postgres://user:password@host.docker.internal:5432/dbname)"
    }
  ],
  "mcpServers": {
    "postgres": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp/postgres",
        "postgres://postgres:postgres@host.docker.internal:5432/olive?sslmode=disable"
      ]
    }
  }
}
