#!/usr/bin/env bash

set -euo pipefail

if ! command -v brew &>/dev/null; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

brew bundle --verbose --file=/dev/stdin <<EOF
brew "chezmoi"
brew "git"

cask "1password"
cask "1password-cli"
cask "ghostty"
cask "font-guguru-sans-code-nf"
cask "rectangle-pro"
cask "zen"
cask "google-chrome"
cask "firefox"
EOF
