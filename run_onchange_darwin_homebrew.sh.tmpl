#!/usr/bin/env bash

set -euo pipefail

if ! command -v brew &>/dev/null; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

brew bundle --verbose --file=/dev/stdin <<EOF
brew "chezmoi"
brew "git"
brew "mas"
brew "imagemagick"

cask "1password"
cask "1password-cli"
cask "ghostty"
cask "font-guguru-sans-code-nf"
cask "google-chrome"
cask "firefox"
cask "obsidian"
cask "karabiner-elements"

mas "Xcode", id:497799835
EOF
