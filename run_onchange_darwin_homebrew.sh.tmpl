#!/usr/bin/env bash

set -euo pipefail

if ! command -v brew &>/dev/null; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

brew bundle --verbose --file=/dev/stdin <<EOF
brew "chezmoi"
brew "git"
brew "mas"

# zsh
brew "zsh"
brew "zsh-completions"
brew "zsh-autosuggestions"
brew "zsh-fast-syntax-highlighting"
brew "olets/tap/zsh-abbr@6"

cask "1password"
cask "1password-cli"
cask "ghostty"
cask "font-guguru-sans-code-nf"
cask "rectangle-pro"
cask "zen"
cask "google-chrome"
cask "firefox"
cask "obsidian"

mas "Xcode", id:497799835
EOF
