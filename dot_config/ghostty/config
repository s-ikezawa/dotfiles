# Ghostty configuration
# Reference: config.default (generated by `ghostty +show-config --default --docs`)

# --- Font ---------------------------------------------------------------
# PlemolJP Console NF = Nerd Font patched, console (half-width) variant
font-family = PlemolJP Console NF
font-size = 14

# --- Theme --------------------------------------------------------------
theme = Catppuccin Mocha

# --- macOS --------------------------------------------------------------
# Treat Option as Alt so Meta/Alt keybindings (e.g. readline M-b / M-f) work.
# Trade-off: this disables macOS Option-based character composition
# (Option+a -> å, etc.).
macos-option-as-alt = true

# --- Window -------------------------------------------------------------
window-padding-x = 8
window-padding-y = 8
window-save-state = always

# --- Misc ---------------------------------------------------------------
copy-on-select = clipboard
mouse-hide-while-typing = true
scrollback-limit = 10000
