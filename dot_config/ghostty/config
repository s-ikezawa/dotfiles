theme = "catppuccin-mocha"

font-family = "UDEV Gothic 35NF Regular"
font-family-bold = "UDEV Gothic 35NF Bold"
font-family-italic = "UDEV Gothic 35NF Italic"
font-family-bold-italic = "UDEV Gothic 35NF BoldItalic"
font-size = 16 

cursor-opacity = 0.6
cursor-style-blink = false

# リサイズした時にsurfaceのサイズがオーバーレイで表示されないようにする
resize-overlay = never 

keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:bottom
keybind = alt+k=goto_split:top
keybind = alt+l=goto_split:right
keybind = alt+shift+h=resize_split:left,20
keybind = alt+shift+j=resize_split:down,20
keybind = alt+shift+k=resize_split:up,20
keybind = alt+shift+l=resize_split:right,20

