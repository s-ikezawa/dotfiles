[user]
	name = Shinichi Ikezawa

[init]
	defaultBranch = main

[core]
	editor = nvim
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
	syntax-theme = Catppuccin-mocha

[pull]
	rebase = true

[push]
	default = current
	autoSetupRemote = true
	followTags = true

[fetch]
	prune = true
	pruneTags = true

[branch]
	sort = -committerdate

[column]
	ui = auto

[diff]
	algorithm = histogram
	colorMoved = default
	colorMovedWS = allow-indentation-change

[merge]
	conflictStyle = zdiff3

[rerere]
	enabled = true
	autoupdate = true

[rebase]
	autoStash = true
	autoSquash = true

[help]
	autocorrect = prompt

[color]
	ui = auto

# コミット署名 (1Password SSH Agent 経由)
# signingkey と gpgsign の有効化は owner ごとの includeIf ファイル側で行う
[gpg]
	format = ssh
[gpg "ssh"]
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
	allowedSignersFile = ~/.config/git/allowed_signers
[commit]
	verbose = true
	gpgsign = false
[tag]
	sort = version:refname
	gpgsign = false

# GitHub の HTTPS URL を SSH 形式に書き換え
# ghq get や HTTPS URL コピペからのクローンでも SSH 経由になる
[url "git@github.com:"]
	insteadOf = https://github.com/

[ghq]
	root = ~/Projects

# 個人情報(メールアドレス・署名鍵)は main config に載せず owner ごとの
# includeIf 側に分離。値は 1Password から chezmoi の onepasswordRead で取得する。
[includeIf "gitdir:~/Projects/github.com/s-ikezawa/"]
	path = config.d/personal
[includeIf "gitdir:~/Projects/github.com/ebisol/"]
	path = config.d/ebisol

[alias]
	co = checkout
	br = branch
	ci = commit
	st = status -sb
	lg = log --oneline --graph --decorate --all
	last = log -1 HEAD --stat
	unstage = reset HEAD --
	amend = commit --amend --no-edit
	root = rev-parse --show-toplevel
