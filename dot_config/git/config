[user]
  name = Shinichi Ikezawa
[init]
  defaultBranch = main
[core]
  excludefile = ~/.config/git/ignore
  editor = nvim
  autocrls = input
  quotepath = false
  pager = delta
[column]
  ui = auto
[branch]
  sort = -committerdate
[tag]
  sort = version:refname
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true     # n / N キーで差分間をジャンプ可能
  side-by-side = true # 左右2分割で差分を表示（広い画面で便利）
  line-numbers = true # 行番号を表示
[merge]
  conflictstyle = zdiff3
[pull]
  rebase = true
[push]
  autoSetupRemote = true # 新規ブランチで初回の push 時の -u を不要にする
  followTags = true # コミットと一緒にタグも push する
[commit]
  verbose = true # コミットメッセージ作成時に差分を表示
[ghq]
  root = ~/Projects

[includeIf "gitdir:~/Projects/github.com/ebisol"]
  path = ~/.config/git/ebisol

[includeIf "gitdir:~/Projects/github.com/s-ikezawa"]
  path = ~/.config/git/private
