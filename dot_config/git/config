[core]
  excludesFile = ~/.config/git/ignore
  pager = delta
  quotepath = false

[color]
  ui = auto

[delta]
  navigate = true
  dark = true
  #side-by-side = true
  line-numbers = true

[fetch]
  prune = true

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictStyle = zdiff3

[pull]
  ff = only

[status]
  showUntrackedFiles = all

[alias]
  plog = log --pretty='format:%C(yellow)%h %C(green)%cd %C(reset)%s %C(red)%d %C(cyan)[%an]' --date=iso
