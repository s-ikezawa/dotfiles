# =============================================================
# 1. プラグイン読み込み(sheldon)
#    plugins.toml 内で「fpath 追加 → compinit → source 系」の
#    順序を管理している(fast-syntax-highlighting を最後に source)
# =============================================================
eval "$(sheldon source)"

# =============================================================
# 2. ツール初期化(eval 系はここに追加していく / compinit より後)
#    - compdef・precmd・プロンプトを使うツールはここに置く
#    - 例: atuin / fzf / starship など
# =============================================================
eval "$(~/.local/bin/mise activate zsh)"
eval "$(zoxide init --cmd cd zsh)"
