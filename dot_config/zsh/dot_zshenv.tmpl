export XDG_CONFIG_HOME=$HOME/.config
export XDG_CACHE_HOME=$HOME/.cache
export XDG_DATA_HOME=$HOME/.local/share
export XDG_STATE_HOME=$HOME/.local/state

# Golang
export GOPATH="$XDG_DATA_HOME/go"
export GOBIN="$XDG_DATA_HOME/go/bin"
export PATH="$GOBIN:$PATH"

{{ if eq .chezmoi.os "darwin" -}}
# PostgreSQL
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"

# MySQL Client 8.0
export PATH="/opt/homebrew/opt/mysql-client@8.0/bin:$PATH"

# Claude
export CLAUDE_CONFIG_DIR="$XDG_CONFIG_HOME/claude"  # 設定ファイルのパス
export CLAUDE_CODE_MAX_OUTPUT_TOKENS=8000           # 出力トークン数を増やす
export DISABLE_NON_ESSENTIAL_MODEL_CALLS=1          # 非必須のモデル呼び出しを無効化（速度向上）

{{ range (onepassword "n67do5qltn7wl3gwj2hpjiavoy").fields -}}
{{   if eq .label "API KEY" -}}
# Context7
export CONTEXT7_API_KEY={{ .value }}
{{ end -}}
{{ end -}}
{{- end }}

