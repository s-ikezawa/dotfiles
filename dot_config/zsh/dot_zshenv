# XDG Base Directory
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# mise
export PATH="${XDG_DATA_HOME:-$HOME/.local/share}/mise/shims:${PATH}"

# Claude Code
export CLAUDE_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude"

# ripgrep(設定ファイルを XDG 配下に置く)
export RIPGREP_CONFIG_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/ripgrep/config"

# Docker CLI(XDG 非対応のため DOCKER_CONFIG で移設。colima は ~/.config/colima を自動使用)
export DOCKER_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/docker"

# Golang
export GOPATH="${XDG_DATA_HOME}/go"
export GOBIN="${GOPATH}/bin"
export PATH="${GOBIN}:${PATH}"

# pnpm
export PNPM_HOME="${XDG_DATA_HOME}/pnpm"
export PATH="${PNPM_HOME}/bin:${PATH}"

# npm(XDG 非対応のため NPM_CONFIG_* で移設。prefix を固定し node バージョンを跨いでグローバルを保持)
export NPM_CONFIG_PREFIX="${XDG_DATA_HOME}/npm"
export NPM_CONFIG_CACHE="${XDG_CACHE_HOME}/npm"
export NPM_CONFIG_USERCONFIG="${XDG_CONFIG_HOME}/npm/npmrc"
export NPM_CONFIG_INIT_MODULE="${XDG_CONFIG_HOME}/npm/config/npm-init.js"
export NPM_CONFIG_LOGS_DIR="${XDG_STATE_HOME}/npm/logs"
export PATH="${NPM_CONFIG_PREFIX}/bin:${PATH}"

# PATH
export PATH="${HOME}/.local/bin:${HOME}/bin:${PATH}"
