#!/usr/bin/env bash

set -euo pipefail

# クリーンインストール直後は zshenv が未読込のため、mise の shims (mas 等) を明示的に通す
export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:$PATH"
export HOMEBREW_CASK_OPTS="--no-quarantine"

if ! command -v brew &>/dev/null; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

brew bundle --verbose --file=/dev/stdin <<EOF
# 必要最低限のCLIはhomebrewで管理する
brew "git"
brew "chezmoi"
brew "mas"
brew "openssl@3"
brew "nss" # mkcertの依存

cask "1password"
cask "1password-cli"
cask "ghostty"
cask "google-chrome"
cask "firefox"
cask "obsidian"
cask "karabiner-elements"
cask "the-unarchiver"
cask "rectangle-pro"
cask "hammerspoon"
cask "kotlin-lsp"

# Font
cask "font-moralerspace"
cask "font-moralerspace-hw"
cask "font-moralerspace-hw-jpdoc"
cask "font-moralerspace-jpdoc"

mas "Xcode", id:497799835
EOF
