#!/usr/bin/env bash

{{ if (or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux")) -}}
mkdir -p $HOME/.config/zsh $HOME/.cache/zsh $HOME/.local/share $HOME/.local/state
{{- end }}

{{ if eq .chezmoi.os "darwin" -}}
# Dock
## サイズ
defaults write com.apple.dock tilesize -int 16 # min:1 max: 128
## 拡大
defaults write com.apple.dock magnification -bool true
defaults write com.apple.dock largesize -int 32 # min:1 max: 128
## 位置
defaults write com.apple.dock orientation -string "left" # left or right or down
## ウィンドウをしまう時のエフェクト
defaults write com.apple.dock mineffect -string "scale" # scale or genie
## 自動で非表示にする
defaults write com.apple.dock autohide -bool true
## 最近使ったアプリをDockに表示しない
defaults write com.apple.dock show-recents -bool false

# Finder
## 隠しファイルを常に表示する
defaults write com.apple.finder AppleShowAllFiles -bool YES
## タイトルバーにフルパスを表示する
defaults write com.apple.finder _FXShowPosixPathInTitle -bool true
## 名前で並び替えを選択時にディレクトリを前に置くようにする
defaults write com.apple.finder _FXSortFoldersFirst -bool true

# Key Repeat
## 入力認識を上げる
defaults write -g InitialKeyRepeat -int 12
## KeyRepeatの速度を上げる
defaults write -g KeyRepeat -int 1
{{- end }}
